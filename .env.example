# Copy this file to backend/.env and fill in your key. backend/.env is gitignored.
# Default working setup: Azure AI Foundry gpt-5.4 for the LLM + local Ollama for embeddings.
# NOTE: the app loads .env with override=True, so these win over any global shell vars.

# ---- LLM: Azure AI Foundry gpt-5.4 (custom provider -> LiteLLM azure/ route) ----
LLM_PROVIDER=custom
LLM_MODEL=azure/gpt-5.4
LLM_ENDPOINT=https://<your-resource>.services.ai.azure.com
LLM_API_KEY=your_azure_key_here
LLM_API_VERSION=2024-10-21
AZURE_API_BASE=https://<your-resource>.services.ai.azure.com
AZURE_API_KEY=your_azure_key_here
AZURE_API_VERSION=2024-10-21

# ---- Embeddings: local Ollama (no key). Requires: ollama + `ollama pull nomic-embed-text`
# and `pip install transformers` (used for the tokenizer). ----
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
HUGGINGFACE_TOKENIZER=bert-base-uncased

# ---- App ----
HINDSIGHT_DATASET=hindsight_decisions

# ---- Slack integration (optional, for live Events API testing) ----
# Required for /integrations/slack/events to accept real Slack requests.
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
# Required to post thread replies through chat.postMessage.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# Local development only: set to true to accept unsigned Slack requests.
HINDSIGHT_SLACK_ALLOW_UNSIGNED=false

# ---- Alternative LLM: Groq (drop-in; comment out the Azure block above) ----
# LLM_PROVIDER=custom
# LLM_MODEL=openai/llama-3.1-8b-instant
# LLM_ENDPOINT=https://api.groq.com/openai/v1
# LLM_API_KEY=your_groq_api_key_here

# Optional: Cognee Cloud mode. Leave blank for local open-source Cognee.
COGNEE_BASE_URL=
COGNEE_API_KEY=
